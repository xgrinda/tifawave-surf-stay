# Supabase project URL, safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon key, safe to expose to the browser when Row Level Security is configured.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public production site URL used for metadata, robots.txt, and sitemap.xml.
NEXT_PUBLIC_SITE_URL=https://tifawave.com

# Server-only key for privileged operations. Never expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Resend API key for server-side booking notification emails.
RESEND_API_KEY=

# Sender must be from a domain verified in Resend.
BOOKING_EMAIL_FROM=Tifawave <bookings@example.com>

# Internal recipient for new pending booking notifications.
BOOKING_NOTIFICATION_EMAIL=hello@tifawave.com

# Temporary password auth for the protected admin dashboard.
ADMIN_PASSWORD=

# Long random secret used to sign the admin session cookie.
ADMIN_SESSION_SECRET=
